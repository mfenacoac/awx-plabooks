// ============================================
// MÉTRICAS DE WINDOWS
// ============================================

prometheus.exporter.windows "default" {
  enabled_collectors = [
    "cpu",
    "logical_disk",
    "net",
    "os",
    "system",
    "cpu_info",
    "memory",
  ]
}

// ============================================
// LOGS DEL SISTEMA WINDOWS (Optimizados)
// ============================================

loki.source.windowsevent "application" {
    eventlog_name = "Application"
    forward_to    = [loki.write.endpoint.receiver]
}

// Mejora: Recolectar log de Sistema pero excluyendo ruido (ej. 7036 = servicio iniciado)
loki.source.windowsevent "system" {
    eventlog_name     = "System"
    exclude_event_ids = "7036,10016" 
    forward_to        = [loki.write.endpoint.receiver]
}

{% for jboss in jboss_instances %}
// ============================================
// JBOSS - {{ jboss.name }}
// ============================================

local.file_match "{{ jboss.name }}_files" {
    path_targets = [
        {"__path__" = "{{ jboss.log_path | replace('\\', '/') }}"}]
    sync_period = "5s"
}

loki.source.file "{{ jboss.name }}_scrape" {
    targets       = local.file_match.{{ jboss.name }}_files.targets
    forward_to    = [loki.process.{{ jboss.name }}_processor.receiver]
    tail_from_end = true
}

loki.process "{{ jboss.name }}_processor" {

    // 1. FILTRO DE RUIDO (Descarta INFO y DEBUG)
    stage.drop {
        expression = "(?i).*(DEBUG|INFO).*"
    }

    // 2. EMPAQUETADO MULTILINE (Para Stack Traces de Java)
    stage.multiline {
        firstline     = "^(\\[[A-Z]+\\] )?\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}"
        max_wait_time = "3s"
    }

    // 3. EXTRACCIÓN DE IDs
    stage.regex {
        expression = ".*span_id=(?P<span_id>[a-f0-9]{16}).*trace_id=(?P<trace_id>[a-f0-9]{32}).*"
    }

    // 4. METADATOS ESTRUCTURADOS (Correlación sin Alta Cardinalidad)
    stage.structured_metadata {
        values = {
            trace_id = "",
            span_id  = "",
        }
    }

    // 5. ETIQUETAS ESTÁTICAS
    stage.static_labels {
        values = {
            job            = "JBOSS_APPL",
            filename       = "log_{{ jboss.name }}",
            service_name   = "JBOSS-APPL",
            environment    = "production",
            hostname       = sys.env("COMPUTERNAME"),
            instance       = "{{ ansible_host }}",
            jboss_instance = "{{ jboss.name }}",
        }
    }

    forward_to = [loki.write.endpoint.receiver]
}
{% endfor %}

// ============================================
// LOGS ESTÁTICOS DE TAFJ (Optimizado con bucle)
// ============================================
{% set tafj_logs = ['database', 'runtime', 'ejb', 'dbimport', 'mdb'] %}

{% for log_type in tafj_logs %}
local.file_match "tafj_{{ log_type }}_files" {
    path_targets = [{"__path__" = "C:\\Temenos\\R18\\TAFJ\\log\\{{ log_type }}.log"}]
    sync_period = "5s"
}

loki.source.file "tafj_{{ log_type }}_scrape" {
    targets    = local.file_match.tafj_{{ log_type }}_files.targets
    forward_to = [loki.process.tafj_{{ log_type }}_processor.receiver]
    tail_from_end = true
}

loki.process "tafj_{{ log_type }}_processor" {
    
    // 1. FILTRO DE RUIDO
    stage.drop {
        expression = "(?i).*(DEBUG|INFO).*"
    }

    // 2. EMPAQUETADO MULTILINE HÍBRIDO
    stage.multiline {
        firstline     = "^(\\[[A-Z]+\\] )?\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}"
        max_wait_time = "3s"
    }

    // 3. EXTRAER IDs CON REGEX
    stage.regex {
        expression = ".*sessionId=(?P<session_id>[^,}]+).*span_id=(?P<span_id>[a-f0-9]{16}).*trace_id=(?P<trace_id>[a-f0-9]{32}).*"
    }
    
    // 4. METADATOS ESTRUCTURADOS (Correlación Segura)
    stage.structured_metadata {
        values = {
            trace_id   = "",
            span_id    = "",
            session_id = "",
        }
    }
    
    // 5. ETIQUETAS ESTÁTICAS
    stage.static_labels {
        values = {
            job          = "TAFJ",
            filename     = "log_tafj_{{ log_type }}",
            log_type     = "{{ log_type }}",
            service_name = "JBOSS-APPL",
            environment  = "production",
            hostname     = sys.env("COMPUTERNAME"),
            instance     = "{{ ansible_host }}",  // IP del Agente
            application  = "T24",
            client       = "APPL",
        }
    }
    
    forward_to = [loki.write.endpoint.receiver]
}
{% endfor %}

// ============================================
// LOGS TEMPORALES - Info2 
// ============================================
local.file_match "temp_files" {
    path_targets = [{"__path__" = "C:\\temp\\info2.log"}]
    sync_period = "5s"
}

loki.source.file "temp_scrape" {
    targets    = local.file_match.temp_files.targets
    forward_to = [loki.process.temp_processor.receiver]
    tail_from_end = false
}

loki.process "temp_processor" {
    stage.static_labels {
        values = {
            job      = "temp-logs",
            filename = "log_temp_info2",
            server   = sys.env("COMPUTERNAME"),
            instance = "{{ ansible_host }}",
            source   = "info2",
        }
    }
    forward_to = [loki.write.endpoint.receiver]
}

// ============================================
// ENDPOINT LOKI (Parametrizado)
// ============================================
loki.write "endpoint" {
    endpoint {
        // Uso de variable de Ansible para la IP central
        url = "http://{{ grafana_server_ip }}:3100/loki/api/v1/push"
        
        retry_on_http_429 = true
        max_backoff_period = "5m"
        min_backoff_period = "1s"
    }
    
    external_labels = {
        cluster = "production",
        datacenter = "main",
    }
}

// ============================================
// ENDPOINT PROMETHEUS (Parametrizado + WAL)
// ============================================
prometheus.remote_write "default" {
    endpoint {
        // Uso de variable de Ansible
        url = "http://{{ grafana_server_ip }}:9090/api/v1/write"
        
        queue_config {
            capacity = 10000
            max_shards = 50
            min_shards = 1
            max_samples_per_send = 5000
            batch_send_deadline = "5s"
            min_backoff = "30ms"
            max_backoff = "5s"
        }
    }

    // Tolerancia a fallos: Guarda en disco si se cae la red
    wal {
        truncate_frequency = "2h"
    }
    
    external_labels = {
        cluster = "production",
        datacenter = "main",
    }
}

// ============================================
// TRAZAS - OTLP RECEIVER
// ============================================
otelcol.receiver.otlp "default" {
    grpc {
        endpoint = "0.0.0.0:4317" 
    }
    http {
        endpoint = "0.0.0.0:4318"
    }
    output {
        metrics = [otelcol.processor.attributes.add_service_info.input]
        logs    = [otelcol.processor.attributes.add_service_info.input]
        traces  = [otelcol.processor.attributes.add_service_info.input]
    }
}

otelcol.processor.attributes "add_service_info" {
    action {
        key    = "deployment.environment"
        value  = "production"
        action = "upsert"
    }
    action {
        key    = "host.ip"
        value  = "{{ ansible_host }}"
        action = "upsert"
    }
    action {
        key    = "cluster"
        value  = "production"
        action = "upsert"
    }
    
    output {
        metrics = [otelcol.processor.batch.default.input]
        logs    = [otelcol.processor.batch.default.input]
        traces  = [otelcol.processor.batch.default.input]
    }
}

otelcol.processor.batch "default" {
    timeout = "5s"
    send_batch_size = 2048
    send_batch_max_size = 4096
    
    output {
        metrics = [otelcol.exporter.otlp.tempo.input]
        logs    = [otelcol.exporter.loki.default.input]
        traces  = [otelcol.exporter.otlp.tempo.input]
    }
}

// ============================================
// ENDPOINT TEMPO (Parametrizado)
// ============================================
otelcol.exporter.otlp "tempo" {
    client {
        // Uso de variable de Ansible
        endpoint = "http://{{ grafana_server_ip }}:4317" 
        tls {
            insecure = true
        }
    }
}

// ============================================
// EXPORTAR LOGS OTLP A LOKI (El bloque que faltaba)
// ============================================
otelcol.exporter.loki "default" {
    forward_to = [loki.write.endpoint.receiver]
}
