logging {
  level = "info"
}

// ============================================
// MÉTRICAS DE WINDOWS
// ============================================
prometheus.exporter.windows "default" {
  enabled_collectors = [
    "cpu", "logical_disk", "net", "os", "system", "cpu_info", "memory", "time",
  ]
}

prometheus.scrape "windows_exporter" {
    targets    = prometheus.exporter.windows.default.targets
    forward_to = [prometheus.relabel.windows_tags.receiver]
    scrape_interval = "15s" 
}

prometheus.relabel "windows_tags" {
    forward_to = [prometheus.remote_write.default.receiver]
    rule { target_label = "host_ip"; replacement = "{{ ansible_host }}" }
    rule { target_label = "instance"; replacement = "{{ ansible_host }}" }
    rule { target_label = "job"; replacement = "APPL_TCIB" }
    rule { target_label = "environment"; replacement = "PROD" }
}

// ============================================
// LOGS DEL SISTEMA WINDOWS
// ============================================
loki.source.windowsevent "application" {
    eventlog_name = "Application"
    bookmark_path = "C:\\ProgramData\\GrafanaLabs\\Alloy\\data\\bookmark_app.xml"
    forward_to    = [loki.write.endpoint.receiver]
}

loki.source.windowsevent "system" {
    eventlog_name = "System"
    bookmark_path = "C:\\ProgramData\\GrafanaLabs\\Alloy\\data\\bookmark_sys.xml"
    forward_to    = [loki.write.endpoint.receiver]
}

// ============================================
// JBOSS - CICLO DINÁMICO (Soporta T24 y TCIB)
// ============================================
{% for jboss in jboss_instances %}
local.file_match "{{ jboss.name | lower }}_files" {
    path_targets = [{"__path__" = "{{ jboss.log_path | replace('\\', '/') }}"}]
    sync_period = "15s"
}

loki.source.file "{{ jboss.name | lower }}_scrape" {
    targets       = local.file_match.{{ jboss.name | lower }}_files.targets
    forward_to    = [loki.process.{{ jboss.name | lower }}_processor.receiver]
    tail_from_end = true
}

loki.process "{{ jboss.name | lower }}_processor" {
    stage.drop { expression = "(?i).*(DEBUG|INFO|WARN).*" }
    stage.multiline {
        firstline     = "^(\\[[A-Z]+\\] )?\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}"
        max_wait_time = "3s"
    }
    stage.regex { expression = ".*span_id=(?P<span_id>[a-f0-9]{16}).*trace_id=(?P<trace_id>[a-f0-9]{32}).*" }
    stage.structured_metadata { values = { trace_id = "", span_id  = "" } }
    stage.static_labels {
        values = {
            job            = "{{ jboss.job_name }}",
            filename       = "LOG_SERVER_{{ jboss.name }}",
            service_name   = "{{ jboss.service_name }}",
            environment    = "PROD",
            hostname       = sys.env("COMPUTERNAME"),
            instance       = "{{ ansible_host }}",
            jboss_instance = "{{ jboss.name }}",
        }
    }
    forward_to = [loki.write.endpoint.receiver]
}
{% endfor %}

// ============================================
// LOGS DINÁMICOS - DEBUG VFS (Solo para TCIB)
// ============================================
{% if enable_vfs_debug_logs | default(false) %}
local.file_match "Debug_files" {
    path_targets = [{"__path__" = "C:/Temenos/R18/jboss-eap-7.1/standalone/tmp/vfs/temp/*/*/logs/Debug.log"}]
    sync_period = "15s" 
}

loki.source.file "Debug_scrape" {
    targets       = local.file_match.Debug_files.targets
    forward_to    = [loki.process.debug_processor.receiver] 
    tail_from_end = false
}

loki.process "debug_processor" {
    stage.static_labels {
        values = {
            job          = "DEBUG_APPL_TCIB_{{ ansible_host.split('.')[-1] }}",
            filename     = "LOG_DEBUG",
            service_name = "TCIB",
            environment  = "PROD",
            hostname     = sys.env("COMPUTERNAME"),
            instance     = "{{ ansible_host }}",
        }
    }
    forward_to = [loki.write.endpoint.receiver]
}
{% endif %}

// ============================================
// LOGS ESTÁTICOS DE TAFJ (Solo para T24)
// ============================================
{% if enable_tafj_logs | default(false) %}
{% set tafj_logs = ['database', 'runtime', 'ejb', 'dbimport', 'mdb'] %}
{% for log_type in tafj_logs %}
local.file_match "tafj_{{ log_type }}_files" {
    path_targets = [{"__path__" = "C:\\Temenos\\R18\\TAFJ\\log\\{{ log_type }}.log"}]
    sync_period = "5s"
}
loki.source.file "tafj_{{ log_type }}_scrape" {
    targets    = local.file_match.tafj_{{ log_type }}_files.targets
    forward_to = [loki.process.tafj_{{ log_type }}_processor.receiver]
    tail_from_end = true
}
loki.process "tafj_{{ log_type }}_processor" {
    stage.drop { expression = "(?i).*(DEBUG|INFO|WARN).*" }
    stage.multiline {
        firstline     = "^(\\[[A-Z]+\\] )?\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}"
        max_wait_time = "3s"
    }
    stage.regex { expression = ".*sessionId=(?P<session_id>[^,}]+).*span_id=(?P<span_id>[a-f0-9]{16}).*trace_id=(?P<trace_id>[a-f0-9]{32}).*" }
    stage.structured_metadata { values = { trace_id = "", span_id = "", session_id = "" } }
    stage.static_labels {
        values = {
            job          = "TAFJ",
            filename     = "log_tafj_{{ log_type }}",
            log_type     = "{{ log_type }}",
            service_name = "JBOSS-APPL",
            environment  = "PROD",
            hostname     = sys.env("COMPUTERNAME"),
            instance     = "{{ ansible_host }}",
            application  = "T24",
            client       = "APPL",
        }
    }
    forward_to = [loki.write.endpoint.receiver]
}
{% endfor %}
{% endif %}

// ============================================
// LOGS TEMPORALES - Info2 (Solo para T24)
// ============================================
{% if enable_temp_info2 | default(false) %}
local.file_match "temp_files" {
    path_targets = [{"__path__" = "C:\\temp\\info2.log"}]
    sync_period = "5s"
}
loki.source.file "temp_scrape" {
    targets    = local.file_match.temp_files.targets
    forward_to = [loki.process.temp_processor.receiver]
    tail_from_end = false
}
loki.process "temp_processor" {
    stage.static_labels {
        values = { job = "temp-logs", filename = "log_temp_info2", server = sys.env("COMPUTERNAME"), instance = "{{ ansible_host }}", source = "info2" }
    }
    forward_to = [loki.write.endpoint.receiver]
}
{% endif %}

// ============================================
// TRAZAS - OTLP RECEIVER Y CONVERSORES
// ============================================
otelcol.receiver.otlp "default" {
    grpc { endpoint = "0.0.0.0:4317" }
    http { endpoint = "0.0.0.0:4318" }
    output {
        metrics = [otelcol.processor.attributes.add_service_info.input]
        logs    = [otelcol.processor.attributes.add_service_info.input]
        traces  = [otelcol.processor.attributes.add_service_info.input]
    }
}

otelcol.processor.attributes "add_service_info" {
    action { key = "service.name"; value = "jboss-eap"; action = "upsert" }
    action { key = "service.version"; value = "7.1"; action = "upsert" }
    action { key = "client"; value = "{{ otlp_client_name | default('APPL') }}"; action = "upsert" }
    action { key = "environment"; value = "PROD"; action = "upsert" }
    action { key = "host.name"; value = sys.env("COMPUTERNAME"); action = "upsert" }
    action { key = "host_ip"; value = "{{ ansible_host }}"; action = "upsert" }
    
    output {
        metrics = [otelcol.processor.batch.default.input]
        logs    = [otelcol.processor.batch.default.input]
        traces  = [otelcol.processor.batch.default.input]
    }
}

otelcol.processor.batch "default" {
    timeout = "5s"
    send_batch_size = 2048
    send_batch_max_size = 4096
    output {
        metrics = [otelcol.exporter.prometheus.default.input]
        logs    = [otelcol.exporter.loki.default.input]
        traces  = [otelcol.exporter.otlp.tempo.input]
    }
}

otelcol.exporter.prometheus "default" { forward_to = [prometheus.remote_write.default.receiver] }
otelcol.exporter.loki "default" { forward_to = [loki.write.endpoint.receiver] }

// ============================================
// ENDPOINTS DE DESTINO (HACIA GRAFANA CENTRAL/GATEWAY)
// ============================================
loki.write "endpoint" {
    endpoint {
        url = "http://{{ grafana_server_ip | default('10.138.7.20') }}:{{ grafana_loki_port | default('3100') }}/loki/api/v1/push"
        retry_on_http_429 = true
        max_backoff_period = "5m"
        min_backoff_period = "1s"
    }
    wal { enabled = true; max_segment_age = "1h" }
}

prometheus.remote_write "default" {
    endpoint {
        url = "http://{{ grafana_server_ip | default('10.138.7.20') }}:{{ grafana_prometheus_port | default('9090') }}/api/v1/write"
        queue_config {
            capacity = 10000
            max_shards = 50
            min_shards = 1
            max_samples_per_send = 5000
            batch_send_deadline = "5s"
            min_backoff = "30ms"
            max_backoff = "5s"
        }
    }
    wal { truncate_frequency = "2h" }
}

otelcol.exporter.otlp "tempo" {
    client {
        endpoint = "http://{{ grafana_server_ip | default('10.138.7.20') }}:{{ grafana_tempo_port | default('4317') }}" 
        tls { insecure = true }
    }
    // Añadido como mejor práctica para todos los servidores:
    sending_queue {
        enabled       = true
        num_consumers = 10
        queue_size    = 10000
    }
    retry_on_failure {
        enabled          = true
        initial_interval = "5s"
        max_interval     = "30s"
        max_elapsed_time = "300s"
    }
}
