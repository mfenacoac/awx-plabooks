events {}
http {
    server {
        listen 9182;
        server_name localhost;
        
        access_log C:/nginx/logs/access.log;
        error_log C:/nginx/logs/error.log;
        
        location /metrics {
            #auth_basic "Windows Exporter - Protegido";
            #auth_basic_user_file C:/nginx/conf/.htpasswd;
            proxy_pass http://127.0.0.1:12345/api/v0/component/prometheus.exporter.windows.default/metrics;
        }
    }
}
